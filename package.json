{
  "name": "temporal-vortex",
  "version": "0.1.0",
  "description": "A GitLens-like CLI tool for extracting change timestamps from a git repository",
  "main": "dist/cli.js",
  "bin": {
    "tv": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src tests --ext .ts",
    "start": "ts-node src/cli.ts",
    "screenshot": "ts-node scripts/screenshot.ts"
  },
  "keywords": [
    "git",
    "blame",
    "timestamps",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "chalk": "^4.1.2",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "ansi-to-svg": "^1.4.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
